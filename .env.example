# VolatileAI runtime configuration
# Copy this file to .env and edit values.

# Optional: data directory override
# VOLATILEAI_DATA_DIR=/home/your-user/Major/VolatileAI/data

# AI provider: ollama | openai | anthropic | groq | opentext
VOLATILEAI_AI_PROVIDER=ollama
VOLATILEAI_AI_TIMEOUT=120

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# OpenText (OpenAI-compatible endpoint)
OPENTEXT_API_KEY=
OPENTEXT_BASE_URL=
OPENTEXT_MODEL=gpt-4o-mini
